# Hermes3D OS local environment example.
# Copy this file to .env and fill in local values.

HERMES3D_ENV=local
HERMES3D_DATABASE_URL=sqlite:///./data/hermes3d.sqlite

# Local Hermes/model endpoint
HERMES3D_MODEL_BASE_URL=http://127.0.0.1:1234/v1
HERMES3D_MODEL_NAME=your-local-hermes-model
HERMES3D_MODEL_API_KEY=local-not-secret-if-your-server-does-not-require-one

# Pilot printer API keys
MOONRAKER_FLSUN_T1_A_API_KEY=
MOONRAKER_FLSUN_T1_B_API_KEY=
MOONRAKER_FLSUN_S1_API_KEY=
MOONRAKER_FLSUN_V400_API_KEY=

# Optional FDM Monster sidecar
FDM_MONSTER_BASE_URL=http://127.0.0.1:4000
FDM_MONSTER_API_KEY=
